# Frontend
VITE_API_URL=http://localhost:3001/api

# Backend
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Data providers
DATA_PROVIDER=supabase
AUTH_DATA_MODE=database
OTP_DELIVERY=dev
MEDIA_PROVIDER=r2
RESEARCH_LAKE_PROVIDER=r2-research-lake
AI_TRACE_PROVIDER=supabase-ai-trace
DASHBOARD_REALTIME_INTERVAL_MS=1000
SATURATION_REFRESH_INTERVAL_MS=10000
JWT_SECRET=change-this-to-a-strong-32-character-secret
JWT_EXPIRES_IN=7d

# Supabase/Postgres
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=
CLOUDFLARE_R2_ENDPOINT=

# AI provider
# openai = OpenAI API langsung, azure_openai = Azure OpenAI, rules = offline rule-based.
AI_PROVIDER=openai
AI_PROVIDER_STRICT=true
AI_PROVIDER_TIMEOUT_MS=20000
AI_MAX_OUTPUT_TOKENS=0

# OpenAI API langsung
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
